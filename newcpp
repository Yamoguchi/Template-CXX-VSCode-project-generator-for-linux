#!/usr/bin/env bash

set -e

PROJECT_NAME="$1"

# ==========================================
# 0. CHECKS
# ==========================================

if [ -z "$PROJECT_NAME" ]; then
    echo "❌ Error: please provide a project name."
    echo "Usage: newcpp ProjectName"
    exit 1
fi

TARGET_DIR="$(pwd)/$PROJECT_NAME"

if [ -d "$TARGET_DIR" ]; then
    echo "❌ Error: directory '$PROJECT_NAME' already exists."
    exit 1
fi

if ! command -v cmake >/dev/null 2>&1; then
    echo "❌ Error: cmake is not installed."
    echo "Install it with: sudo pacman -S cmake"
    exit 1
fi

if ! command -v ninja >/dev/null 2>&1; then
    echo "❌ Error: ninja is not installed."
    echo "Install it with: sudo pacman -S ninja"
    exit 1
fi

if ! command -v clang++ >/dev/null 2>&1; then
    echo "❌ Error: clang++ is not installed."
    echo "Install it with: sudo pacman -S clang"
    exit 1
fi

if ! command -v code >/dev/null 2>&1; then
    echo "⚠️  Warning: 'code' command was not found."
    echo "The project will be created, but VS Code will not open automatically."
    HAS_CODE=false
else
    HAS_CODE=true
fi

echo "📁 Creating project '$PROJECT_NAME'..."

# ==========================================
# 1. CREATE PROJECT STRUCTURE
# ==========================================

mkdir -p "$TARGET_DIR/.vscode"
mkdir -p "$TARGET_DIR/src"

# ==========================================
# 2. CMakeLists.txt
# ==========================================

cat > "$TARGET_DIR/CMakeLists.txt" <<EOF
cmake_minimum_required(VERSION 3.20)

project($PROJECT_NAME LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 23)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

add_executable($PROJECT_NAME
    src/main.cpp
)

target_compile_options($PROJECT_NAME PRIVATE
    -Wall
    -Wextra
    -Wpedantic
    -Wconversion
    -Wshadow
)
EOF

# ==========================================
# 3. src/main.cpp
# ==========================================

cat > "$TARGET_DIR/src/main.cpp" <<'EOF'
#include <iostream>

int main() {
    std::cout << "Hello, World!" << '\n';
    return 0;
}
EOF

# ==========================================
# 4. .vscode/settings.json
# ==========================================

cat > "$TARGET_DIR/.vscode/settings.json" <<'EOF'
{
    "cmake.generator": "Ninja",

    "cmake.configureSettings": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
    },

    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,

    "clangd.path": "/usr/bin/clangd",

    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--pch-storage=memory",
        "--compile-commands-dir=${workspaceFolder}/build"
    ],

    "C_Cpp.intelliSenseEngine": "disabled",

    "editor.formatOnSave": true,

    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },

    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    }
}
EOF

# ==========================================
# 5. .vscode/tasks.json
# ==========================================

cat > "$TARGET_DIR/.vscode/tasks.json" <<'EOF'
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build project",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
EOF

# ==========================================
# 6. .vscode/launch.json
# ==========================================

cat > "$TARGET_DIR/.vscode/launch.json" <<'EOF'
{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug C++ with CodeLLDB",
            "program": "${workspaceFolder}/build/${workspaceFolderBasename}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build project",
            "terminal": "integrated"
        }
    ]
}
EOF

# ==========================================
# 7. .clang-format
# ==========================================

cat > "$TARGET_DIR/.clang-format" <<'EOF'
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
PointerAlignment: Left
ReferenceAlignment: Left
SortIncludes: true
EOF

# ==========================================
# 8. .clang-tidy
# ==========================================

cat > "$TARGET_DIR/.clang-tidy" <<'EOF'
Checks: >
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast

WarningsAsErrors: ''

HeaderFilterRegex: '.*'

FormatStyle: file
EOF

# ==========================================
# 9. .gitignore
# ==========================================

cat > "$TARGET_DIR/.gitignore" <<'EOF'
build/
.cache/
compile_commands.json
.vscode/.cmake/
EOF

# ==========================================
# 10. README.md
# ==========================================

cat > "$TARGET_DIR/README.md" <<EOF
# $PROJECT_NAME

C++ project generated for Linux using:

- clang
- clangd
- clang-tidy
- clang-format
- CMake
- Ninja
- VS Code
- CodeLLDB

## Build

\`\`\`bash
cmake -S . -B build -G Ninja \\
  -DCMAKE_C_COMPILER=clang \\
  -DCMAKE_CXX_COMPILER=clang++ \\
  -DCMAKE_BUILD_TYPE=Debug \\
  -DCMAKE_EXPORT_COMPILE_COMMANDS=ON

cmake --build build
\`\`\`

## Run

\`\`\`bash
./build/$PROJECT_NAME
\`\`\`

## Debug

Use the following VS Code debug configuration:

\`\`\`text
Debug C++ with CodeLLDB
\`\`\`
EOF

echo "✅ Project created successfully!"

cd "$TARGET_DIR"

if [ "$HAS_CODE" = true ]; then
    echo "🚀 Opening VS Code..."
    code .
else
    echo "📁 Project created at:"
    echo "$TARGET_DIR"
fi
