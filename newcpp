#!/usr/bin/env bash

set -e

PROJECT_NAME=""
USE_VCPKG=false
VCPKG_TOOLCHAIN_FILE=""

# ==========================================
# 0. ARGUMENTS
# ==========================================

for arg in "$@"; do
    case "$arg" in
        --vcpkg)
            USE_VCPKG=true
            ;;
        -h|--help)
            echo "Usage:"
            echo "  newcpp ProjectName"
            echo "  newcpp ProjectName --vcpkg"
            exit 0
            ;;
        *)
            if [ -z "$PROJECT_NAME" ]; then
                PROJECT_NAME="$arg"
            else
                echo "❌ Error: unknown argument '$arg'."
                echo "Usage: newcpp ProjectName [--vcpkg]"
                exit 1
            fi
            ;;
    esac
done

# ==========================================
# 1. CHECKS
# ==========================================

if [ -z "$PROJECT_NAME" ]; then
    echo "❌ Error: please provide a project name."
    echo "Usage: newcpp ProjectName [--vcpkg]"
    exit 1
fi

TARGET_DIR="$(pwd)/$PROJECT_NAME"

if [ -d "$TARGET_DIR" ]; then
    echo "❌ Error: directory '$PROJECT_NAME' already exists."
    exit 1
fi

if ! command -v cmake >/dev/null 2>&1; then
    echo "❌ Error: cmake is not installed."
    echo "Install it with: sudo pacman -S cmake"
    exit 1
fi

if ! command -v ninja >/dev/null 2>&1; then
    echo "❌ Error: ninja is not installed."
    echo "Install it with: sudo pacman -S ninja"
    exit 1
fi

if ! command -v clang++ >/dev/null 2>&1; then
    echo "❌ Error: clang++ is not installed."
    echo "Install it with: sudo pacman -S clang"
    exit 1
fi

if [ "$USE_VCPKG" = true ]; then
    if [ -z "$VCPKG_ROOT" ]; then
        echo "❌ Error: VCPKG_ROOT is not set."
        echo "Set it, for example:"
        echo "  export VCPKG_ROOT=\$HOME/dev/vcpkg"
        exit 1
    fi

    VCPKG_TOOLCHAIN_FILE="$VCPKG_ROOT/scripts/buildsystems/vcpkg.cmake"

    if [ ! -f "$VCPKG_TOOLCHAIN_FILE" ]; then
        echo "❌ Error: vcpkg toolchain file was not found."
        echo "Expected:"
        echo "  $VCPKG_TOOLCHAIN_FILE"
        exit 1
    fi
fi

if ! command -v code >/dev/null 2>&1; then
    echo "⚠️  Warning: 'code' command was not found."
    echo "The project will be created, but VS Code will not open automatically."
    HAS_CODE=false
else
    HAS_CODE=true
fi

echo "📁 Creating project '$PROJECT_NAME'..."

if [ "$USE_VCPKG" = true ]; then
    echo "📦 vcpkg support enabled."
fi

# ==========================================
# 2. CREATE PROJECT STRUCTURE
# ==========================================

mkdir -p "$TARGET_DIR/.vscode"
mkdir -p "$TARGET_DIR/src"

# ==========================================
# 3. CMakeLists.txt
# ==========================================

cat > "$TARGET_DIR/CMakeLists.txt" <<EOF
cmake_minimum_required(VERSION 3.20)

project($PROJECT_NAME LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 23)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_EXTENSIONS OFF)

set(CMAKE_EXPORT_COMPILE_COMMANDS ON)

add_executable($PROJECT_NAME
    src/main.cpp
)

target_compile_options($PROJECT_NAME PRIVATE
    -Wall
    -Wextra
    -Wpedantic
    -Wconversion
    -Wshadow
)
EOF

# ==========================================
# 4. src/main.cpp
# ==========================================

cat > "$TARGET_DIR/src/main.cpp" <<'EOF'
#include <iostream>

int main() {
    std::cout << "Hello, World!" << '\n';
    return 0;
}
EOF

# ==========================================
# 5. CMakePresets.json
# ==========================================

if [ "$USE_VCPKG" = true ]; then
    cat > "$TARGET_DIR/CMakePresets.json" <<EOF
{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build using Ninja, Clang and vcpkg",
            "generator": "Ninja",
            "binaryDir": "\${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_TOOLCHAIN_FILE": "$VCPKG_TOOLCHAIN_FILE"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Release build using Ninja, Clang and vcpkg",
            "generator": "Ninja",
            "binaryDir": "\${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_TOOLCHAIN_FILE": "$VCPKG_TOOLCHAIN_FILE"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        }
    ]
}
EOF
fi

# ==========================================
# 6. vcpkg.json
# ==========================================

if [ "$USE_VCPKG" = true ]; then
    cat > "$TARGET_DIR/vcpkg.json" <<EOF
{
    "name": "$PROJECT_NAME",
    "version-string": "0.1.0",
    "dependencies": []
}
EOF
fi

# ==========================================
# 7. .vscode/settings.json
# ==========================================

if [ "$USE_VCPKG" = true ]; then
    cat > "$TARGET_DIR/.vscode/settings.json" <<'EOF'
{
    "cmake.useCMakePresets": "always",
    "cmake.configureOnOpen": true,
    "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",

    "clangd.path": "/usr/bin/clangd",

    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--pch-storage=memory"
    ],

    "C_Cpp.intelliSenseEngine": "disabled",

    "editor.formatOnSave": true,

    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },

    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    }
}
EOF
else
    cat > "$TARGET_DIR/.vscode/settings.json" <<'EOF'
{
    "cmake.generator": "Ninja",

    "cmake.configureSettings": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
    },

    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",

    "clangd.path": "/usr/bin/clangd",

    "clangd.arguments": [
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--pch-storage=memory"
    ],

    "C_Cpp.intelliSenseEngine": "disabled",

    "editor.formatOnSave": true,

    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },

    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    }
}
EOF
fi

# ==========================================
# 8. .vscode/tasks.json
# ==========================================

cat > "$TARGET_DIR/.vscode/tasks.json" <<'EOF'
{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cmake",
            "label": "CMake: build",
            "command": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "Build using the active CMake Tools configuration"
        }
    ]
}
EOF

# ==========================================
# 9. .vscode/launch.json
# ==========================================

cat > "$TARGET_DIR/.vscode/launch.json" <<'EOF'
{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug CMake Target",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build",
            "terminal": "integrated"
        }
    ]
}
EOF

# ==========================================
# 10. .clang-format
# ==========================================

cat > "$TARGET_DIR/.clang-format" <<'EOF'
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
BreakBeforeBraces: Attach
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
PointerAlignment: Left
ReferenceAlignment: Left
SortIncludes: true
EOF

# ==========================================
# 11. .clang-tidy
# ==========================================

cat > "$TARGET_DIR/.clang-tidy" <<'EOF'
Checks: >
  bugprone-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast

WarningsAsErrors: ''

HeaderFilterRegex: '.*'

FormatStyle: file
EOF

# ==========================================
# 12. .gitignore
# ==========================================

cat > "$TARGET_DIR/.gitignore" <<'EOF'
build/
.cache/
.vscode/.cmake/
EOF

echo "✅ Project created successfully!"

cd "$TARGET_DIR"

if [ "$HAS_CODE" = true ]; then
    echo "🚀 Opening VS Code..."
    code .
else
    echo "📁 Project created at:"
    echo "$TARGET_DIR"
fi
